{
  "AppSettings": {
    "ApplicationName": "DrMusa",
    "Version": "1.0.0",
    "DatabasePath": "database/DrMusa.db",
    "LogPath": "logs/drmusa-.log",
    "Currency": "PKR",
    "DefaultTaxPercent": 0,
    "BackupPath": "database/Backup",
    "AutoBackup": true,
    "AutoBackupDays": 1
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "File", "Args": { "path": "logs/drmusa-.log", "rollingInterval": "Day" } }
    ]
  }
}
